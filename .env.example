# Database
DATABASE_URL="postgresql://user:password@host:5432/vibe_voicer"

# Better Auth
BETTER_AUTH_SECRET="run: openssl rand -hex 32"
# Optional on Vercel: leave empty and the app derives the URL from
# VERCEL_PROJECT_PRODUCTION_URL (production) or VERCEL_URL (previews).
# Set this when you wire up a custom domain.
BETTER_AUTH_URL="http://localhost:3000"
# Comma-separated extra origins to trust beyond the built-in list
TRUSTED_ORIGINS=""

# Social login (optional — providers silently disappear when unset)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
NEXT_PUBLIC_GITHUB_CLIENT_ID=""

# Recurring-invoice cron (required for /api/cron/recurring-invoice)
# Generate: openssl rand -hex 32
CRON_SECRET=""

# Gmail SMTP (required to actually send emails)
# GMAIL_APP_PASSWORD is a 16-char App Password from
# https://myaccount.google.com/apppasswords (requires 2FA on the Google account).
GMAIL_USER=""
GMAIL_APP_PASSWORD=""

# Optional. Defaults to GMAIL_USER. Accepts RFC 5322 form: Josh <josh@gmail.com>
MAIL_FROM=""

# Optional. If set, every recurring-invoice email goes here instead of the
# client's address. Useful for staging/preview deploys; leave empty in prod.
MAIL_TO_OVERRIDE=""

# Optional. Defaults to jay.designs716@gmail.com. The User row that scopes the
# "Rachel" client + invoice lookups.
RECURRING_USER_EMAIL=""
